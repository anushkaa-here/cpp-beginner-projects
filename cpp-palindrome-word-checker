#include <iostream>
#include <string>
using namespace std;

int main() {
    string word;
    bool isPalindrome = true;

    cout << "Enter a word: ";
    cin >> word;

    int n = word.length();

    for(int i = 0; i < n/2; i++) {
        if(word[i] != word[n-i-1]) {
            isPalindrome = false;
            break;
        }
    }

    if(isPalindrome)
        cout << word << " is a palindrome.";
    else
        cout << word << " is not a palindrome.";

    return 0;
}
